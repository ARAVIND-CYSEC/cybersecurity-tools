{
  "endpoint": "POST /api/file/analysis",
  "contentType": "multipart/form-data",
  "form": { "file": "<binary>" },
  "response": {
    "artifact": {
      "fileName": "string",
      "fileSize": "number"
    },
    "hashes": {
      "sha1": "string",
      "sha256": "string",
      "ssdeep": "string|null",
      "tlsh": "string|null"
    },
    "structure": {
      "magic": "string|null",
      "entropy": "number|null",
      "strings": { "count": "number", "sample": ["string"] }
    },
    "behavior": {
      "notes": ["string"],
      "detonation": { "performed": false }
    },
    "scoring": {
      "score": "number 0-100",
      "band": "low|medium|high",
      "reasons": ["string"]
    }
  }
}

